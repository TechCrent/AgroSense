# Paste into Render → Web Service → Environment (do not commit real values).
# Guide: docs/DEPLOYMENT.md

SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=your-service.onrender.com

# --- Database ---
# Default: leave DATABASE_URL unset → Django uses SQLite (backend/db.sqlite3).
# Optional Postgres: set DATABASE_URL to Internal Database URL from Render Postgres.
# DATABASE_URL=postgresql://...

# --- CORS / CSRF (Vercel origin(s), https, no trailing slash; comma-separated for preview + prod) ---
CORS_ALLOWED_ORIGINS=https://your-project.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-project.vercel.app

LOG_LEVEL=INFO

CLAUDE_API_KEY=
PLANT_DETECTION_API_KEY=
PLANT_API_URL=https://api.plant.id/v3
PLANTHEALTH_API_KEY=
PLANTHEALTH_API_URL=https://crop.kindwise.com/api/v1

# --- Translator (optional — diagnosis localization) ---
# Ghana NLP (preferred)
API_URL=https://translation-api.ghananlp.org/v1/translate
API_SUPPORTED_LANGUAGES_URL=https://translation-api.ghananlp.org/v1/languages
PRIMARY_API_KEY=
SECONDARY_API_KEY=
# Khaya / Lelapa (legacy fallback)
KHAYA_API_TOKEN=
# KHAYA_TRANSLATE_URL=https://api.lelapa.ai/v1/translate/process

# --- Gemini (identify-crop-advice) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_API_METHOD=streamGenerateContent
GEMINI_THINKING_LEVEL=HIGH
GEMINI_USE_GOOGLE_SEARCH=True
