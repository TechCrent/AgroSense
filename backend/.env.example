# Local copy to .env and fill in values.

SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Render / production: use your Render hostname and Vercel origin(s), e.g.
# ALLOWED_HOSTS=agrosense-orbp.onrender.com
# CORS_ALLOWED_ORIGINS=https://agro-sense-six.vercel.app
# CSRF_TRUSTED_ORIGINS=https://agro-sense-six.vercel.app
# (Add preview URLs comma-separated if you test preview deployments against this API.)
# Optional Postgres (omit for SQLite — default when unset):
# DATABASE_URL=postgres://user:pass@dpg-xxxxx-a.region-postgres.render.com:5432/dbname

LOG_LEVEL=INFO

CLAUDE_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
PLANT_DETECTION_API_KEY=
PLANT_API_URL=https://api.plant.id/v3

# Optional: Khaya / Lelapa — translate diagnosis (and locale tooling uses the same token)
# KHAYA_API_TOKEN=
# KHAYA_TRANSLATE_URL=https://api.lelapa.ai/v1/translate/process
