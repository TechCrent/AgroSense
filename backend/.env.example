# Local copy to .env and fill in values.

SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Production on Render — see docs/DEPLOYMENT.md and backend/.env.render.template
# ALLOWED_HOSTS=your-service.onrender.com
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
# CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app
# Optional Postgres (omit for SQLite when unset):
# DATABASE_URL=postgres://user:pass@host:5432/dbname

LOG_LEVEL=INFO

# --- Main product API (`/api/scan`, `/api/confirm`) — Plant.id v3 ---
# LLM provider (current backend uses OpenRouter in api/clients/claude_client.py)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
# OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
# Legacy Anthropic vars kept for fallback compatibility:
CLAUDE_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
PLANT_DETECTION_API_KEY=
# Optional: if set in the environment, it overrides PLANT_DETECTION_API_KEY (same as legacy integration).
# PLANT_ID_API_KEY=
PLANT_API_URL=https://api.plant.id/v3

# --- Legacy `core` Kindwise crop + Gemini (only if you mount `core` URLs) ---
PLANTHEALTH_API_KEY=
PLANTHEALTH_API_URL=https://crop.kindwise.com/api/v1

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_API_METHOD=streamGenerateContent
GEMINI_THINKING_LEVEL=HIGH
GEMINI_USE_GOOGLE_SEARCH=True

KHAYA_API_TOKEN=
