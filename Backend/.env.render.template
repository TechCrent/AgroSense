# =============================================================================
# Render Web Service — Environment variables (copy into Render → Environment)
# Do NOT commit real secrets. Replace <...> placeholders after copy-paste.
# =============================================================================

# --- Django core ---
# Generate:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=<generate-a-long-random-string>

DEBUG=False

# Your Render hostname only (no https, no path). Comma-separated if multiple.
ALLOWED_HOSTS=<your-service-name>.onrender.com

# --- Database (Render PostgreSQL → Internal Database URL, or External if needed) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# --- CORS / CSRF (your Vercel app origin(s), https, no trailing slash) ---
# Comma-separated if you have preview + production URLs.
CORS_ALLOWED_ORIGINS=https://<your-project>.vercel.app
CSRF_TRUSTED_ORIGINS=https://<your-project>.vercel.app

# --- Logging ---
LOG_LEVEL=INFO

# --- Kindwise / plant.id ---
PLANT_DETECTION_API_KEY=<kindwise-plant-id-key>
PLANT_API_URL=https://api.plant.id/v3

# --- Kindwise crop ---
PLANTHEALTH_API_KEY=<kindwise-crop-key>
PLANTHEALTH_API_URL=https://crop.kindwise.com/api/v1

# --- Claude (AgroSense scan/confirm integration) ---
CLAUDE_API_KEY=<anthropic-api-key>

# --- Khaya translation (optional) ---
KHAYA_API_TOKEN=

# --- Gemini (identify-crop-advice) ---
GEMINI_API_KEY=<google-ai-studio-key>
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_API_METHOD=streamGenerateContent
GEMINI_THINKING_LEVEL=HIGH
GEMINI_USE_GOOGLE_SEARCH=True
