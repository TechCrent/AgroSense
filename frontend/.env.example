# Local dev: leave empty — Vite proxies /api → http://127.0.0.1:8000 (see vite.config.js).
#
# Production (Vercel) — pick one:
# (A) Leave empty: browser calls /api on your Vercel domain; repo-root vercel.json rewrites to Render.
#     Update the rewrite URL if your Render service hostname changes.
# (B) Set VITE_API_BASE_URL to your Render origin (no trailing slash) in Vercel → Environment Variables
#     for Production (and Preview if needed), then redeploy so Vite inlines it.
VITE_API_BASE_URL=

# Examples:
# VITE_API_BASE_URL=http://127.0.0.1:8000
# VITE_API_BASE_URL=https://agrosense-orbp.onrender.com

# Optional: change proxy target when running `npm run dev` (shell env, not VITE_*)
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Offline UI only (no backend):
# VITE_DEV_MOCK=true

# Legacy dev-only: optional FastAPI shim on port 8787 (not in repo by default):
# VITE_API_BASE_URL=http://127.0.0.1:8787
# (and do not rely on /api proxy, or set VITE_API_PROXY_TARGET=http://127.0.0.1:8787)
