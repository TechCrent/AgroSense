# With Django on :8000 (default): leave empty — Vite proxies /api → http://127.0.0.1:8000
VITE_API_BASE_URL=

# If Django runs elsewhere:
# VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: change proxy target when running `npm run dev` (shell env, not VITE_*)
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Offline UI only (no backend):
# VITE_DEV_MOCK=true

# Standalone integration dev API (no Django) on port 8787:
# VITE_API_BASE_URL=http://127.0.0.1:8787
# (and do not rely on /api proxy, or set VITE_API_PROXY_TARGET=http://127.0.0.1:8787)
