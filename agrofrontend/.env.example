# See docs/DEVELOPMENT.md for local setup.

# --- Local dev ---
# Leave empty: browser → Vite → proxy /api → Django :8000 (vite.config.js).
VITE_API_BASE_URL=

# --- Production build ---
# Set to your deployed API origin (https, no trailing slash) before `npm run build`.
# VITE_API_BASE_URL=https://api.example.com

# Direct local API (optional; configure CORS on Django):
# VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: proxy target for `npm run dev` only (not VITE_*)
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Offline UI (no backend):
# VITE_DEV_MOCK=true

# integration/dev_api.py on :8787 (see integration/INTEGRATION.md):
# VITE_API_BASE_URL=http://127.0.0.1:8787
