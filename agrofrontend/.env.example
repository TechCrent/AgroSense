# See docs/DEVELOPMENT.md (local) and docs/DEPLOYMENT.md (Vercel + Render).

# --- Local dev ---
# Leave empty: browser → Vite → proxy /api → Django :8000 (vite.config.js).
VITE_API_BASE_URL=

# --- Vercel Production / Preview ---
# Required for deployed builds (no Vite proxy). Set in Vercel → Project → Settings → Environment Variables.
# Value = Render API origin only — https, no trailing slash, e.g. https://agrosense-backend.onrender.com
# VITE_API_BASE_URL=https://your-backend.onrender.com

# Direct local API (optional; then configure CORS on Django):
# VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: proxy target for `npm run dev` only (not VITE_*)
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Offline UI (no backend):
# VITE_DEV_MOCK=true

# integration/dev_api.py on :8787 (see integration/INTEGRATION.md):
# VITE_API_BASE_URL=http://127.0.0.1:8787
