# Real APIs (default): leave VITE_DEV_MOCK unset or false, run integration dev server:
#   python -m uvicorn integration.dev_api:app --reload --host 127.0.0.1 --port 8787
# Use empty base URL so Vite proxies /api → 8787 (see vite.config.js).
VITE_API_BASE_URL=

# Offline UI only — no Plant.id / Claude / Khaya:
# VITE_DEV_MOCK=true

# Or bypass Vite proxy and call the dev API directly:
# VITE_API_BASE_URL=http://127.0.0.1:8787
