# Local dev: leave empty — Vite proxies /api → http://127.0.0.1:8000 (see vite.config.js).
# Production (Vercel): REQUIRED — there is no proxy. Set in Vercel → Settings → Environment Variables
# for Production (and Preview if you use it), then redeploy. No trailing slash.
VITE_API_BASE_URL=

# Examples:
# VITE_API_BASE_URL=http://127.0.0.1:8000
# VITE_API_BASE_URL=https://agrosense-backend.onrender.com

# Optional: change proxy target when running `npm run dev` (shell env, not VITE_*)
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Offline UI only (no backend):
# VITE_DEV_MOCK=true

# Standalone integration dev API (no Django) on port 8787:
# VITE_API_BASE_URL=http://127.0.0.1:8787
# (and do not rely on /api proxy, or set VITE_API_PROXY_TARGET=http://127.0.0.1:8787)
