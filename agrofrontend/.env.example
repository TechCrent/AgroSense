# See docs/DEVELOPMENT.md (local) and docs/DEPLOYMENT.md (Vercel + Render).

# --- Local dev ---
# Leave empty: Vite proxies /api → Django :8000 (vite.config.js).
VITE_API_BASE_URL=

# --- Vercel production ---
# Required for deployed builds. Set in Vercel → Project → Settings → Environment Variables.
# Value = Render API origin: https://<service>.onrender.com (no trailing slash). Redeploy after changes.
# VITE_API_BASE_URL=https://your-backend.onrender.com

# Direct local API (optional; set CORS on Django):
# VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: proxy target for `npm run dev` only
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Offline UI:
# VITE_DEV_MOCK=true

# integration/dev_api.py :8787 — see integration/INTEGRATION.md
# VITE_API_BASE_URL=http://127.0.0.1:8787
